// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/go
{
    "name": "Go Development Environment",
    "build": {
        "dockerfile": "Dockerfile",
        "options": [
            "--platform=linux/amd64"
        ]
    },
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": "true",
            "username": "vscode",
            "userUid": "1000",
            "userGid": "1000",
            "upgradePackages": "true"
        },
        "ghcr.io/devcontainers/features/git:1": {
            "version": "latest",
            "ppa": "false"
        },
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
        "ghcr.io/devcontainers-extra/features/protoc:1": {},
        "ghcr.io/devcontainers-community/features/llvm": {}
    },
    "containerEnv": {
        "TZ": "Asia/Shanghai",
        "GOOGLE_CLOUD_PROJECT": "${localEnv:GOOGLE_CLOUD_PROJECT}"
    },
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined"
    ],
    "mounts": [
        {
            "source": "/var/run/docker.sock",
            "target": "/var/run/docker.sock",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}/.gemini",
            "target": "/home/vscode/.gemini",
            "type": "bind"
        }
    ],
    "postCreateCommand": "",
    "customizations": {
        "vscode": {
            "settings": {
                "go.toolsManagement.checkForUpdates": "local",
                "go.useLanguageServer": true,
                "go.gopath": "/go",
                "go.lintTool": "golangci-lint",
                "go.formatTool": "goimports",
                "yaml.schemas": {
                    "https://raw.githubusercontent.com/golangci/golangci-lint/refs/heads/main/jsonschema/golangci.v2.4.jsonschema.json": ".golangci.yaml"
                }
            },
            "extensions": [
                "ms-vscode.makefile-tools",
                "ms-vscode.cpptools-themes",
                "vscode-icons-team.vscode-icons",
                "tamasfe.even-better-toml",
                "github.vscode-github-actions",
                "eamodio.gitlens",
                "golang.go",
                "quillaja.goasm",
                "maxmedia.go-prof",
                "visualstudioexptteam.vscodeintellicode",
                "zxh404.vscode-proto3",
                "mfuentesg.vscode-protolint",
                "davidanson.vscode-markdownlint",
                "mohsen1.prettify-json",
                "ms-azuretools.vscode-docker",
                "github.copilot",
                "redhat.vscode-yaml",
                "xaver.clang-format",
                "bufbuild.vscode-buf@0.7.0"
            ]
        }
    },
    "remoteUser": "vscode"
}

